# The Sentinel — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Required: News ───────────────────────────────────────────────────────────
# Get free key at: https://finnhub.io → Sign Up → API Keys
FINNHUB_API_KEY=your_finnhub_api_key_here

# ─── Required: LLM (choose at least one) ─────────────────────────────────────
# Gemini 2.0 Flash-Lite — ~$0.12/month. Get key: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek V3.2 — fallback. Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ─── Required: Telegram Alerts ────────────────────────────────────────────────
# Create bot: open Telegram → @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Find chat_id: message your bot, then visit:
# https://api.telegram.org/bot{YOUR_TOKEN}/getUpdates → copy "id" from "chat"
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Optional: Reddit (social sentiment) ─────────────────────────────────────
# Create app: https://www.reddit.com/prefs/apps → Create App → script type
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=SentinelBot/1.0 by YourRedditUsername

# ─── Optional: Alpaca Paper Trading ──────────────────────────────────────────
# Sign up free: https://alpaca.markets → Paper Trading → Generate API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ─── Optional: Database path (default: sentinel.db in project root) ──────────
# DB_PATH=sentinel.db
